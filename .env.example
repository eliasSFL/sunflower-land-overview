# Sunflower Land public asset CDN. Mirrors upstream's `PROTECTED_IMAGE_URL`
# and drives every `SUNNYSIDE.*`, `CROP_LIFECYCLE`, item-image, and chrome
# border URL the overview renders. Override locally to point at a staging
# CDN; leave unset to use the mainnet default baked into vite.config.ts.
VITE_PRIVATE_IMAGE_URL=https://sunflower-land.com/game-assets

# Which Sunflower Land network the overview talks to. Affects the Bud NFT
# image domain (`buds.sunflower-land.com` vs `testnet-buds.sunflower-land.com`)
# and should match the API the overview's Worker proxies to.
# Values: "mainnet" | "testnet"
VITE_NETWORK=mainnet

# Optional donation address shown in the header's top-right stack. The
# UI renders a truncated form and copies the full string to the clipboard
# on click. Leave empty to hide. Any string is accepted (EVM address,
# SOL pubkey, etc.) — no chain-specific validation.
VITE_DONATION_ADDRESS=

# VAPID public key for Web Push subscriptions (PWA phase 2 notifications).
# Base64url-encoded raw P-256 public key (65 bytes uncompressed). Pair
# with VAPID_PRIVATE and VAPID_SUBJECT in Cloudflare secrets. Generate
# both halves with `npx web-push generate-vapid-keys`. Leaving this
# empty disables the subscribe flow in the UI.
VITE_VAPID_PUBLIC=
