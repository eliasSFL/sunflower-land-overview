{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.sunflower-land.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noCheck": true,
    "outDir": "./node_modules/.cache/sunflower-land-types",
    "rootDir": "./sunflower-land",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "strict": true,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "types": [],
    "paths": {
      "features/community/lib/CommunitySDK": [
        "./src/game/stubs/community-sdk-stub.ts"
      ],
      "features/*": ["./sunflower-land/src/features/*"],
      "lib/*": ["./sunflower-land/src/lib/*"],
      "components/*": ["./sunflower-land/src/components/*"],
      "metadata/*": ["./sunflower-land/metadata/*"],
      "assets/*": ["./sunflower-land/src/assets/*"],
      "src/*": ["./sunflower-land/src/*"]
    }
  },
  "include": [
    "sunflower-land/src/**/*.ts",
    "sunflower-land/src/**/*.tsx",
    "sunflower-land/metadata/**/*.ts"
  ],
  "exclude": [
    "sunflower-land/src/**/__tests__/**",
    "**/*.test.ts",
    "sunflower-land/src/features/community/lib/CommunitySDK.ts"
  ]
}
