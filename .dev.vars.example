# Local-dev secrets for wrangler. Wrangler reads `.dev.vars` (gitignored)
# automatically when running `wrangler dev`. Production uses Cloudflare
# dashboard secrets (Settings → Variables and Secrets → Type: Secret).
#
# Generate a *local* VAPID keypair with:
#   npx web-push generate-vapid-keys --json
# Don't reuse production keys here — the public key is baked into push
# subscriptions on each device, so mixing prod & dev keys will break
# pushes.

VAPID_PUBLIC=
VAPID_PRIVATE=

# API base the Worker proxies to. Mirrors the game client's VITE_API_URL.
# Leave blank ⇒ production (https://api.sunflower-land.com). Set it to a
# personal SST stage's raw API Gateway URL (`api-<stage>`, found in the
# api repo's .sst/pulumi/.../<stage>.json under resource `ApiApi`) to
# develop against that stage. NOTE: SFL_COMMUNITY_API_KEY below must be
# signed with that stage's COMMUNITY_API_KEY_SECRET or upstream 401s.
SFL_API_URL=

# Master HMAC secret for community API key minting. Same value as the
# Cloudflare prod secret. Without it, /api/farms/:id can't mint a
# per-farm key and upstream fetches will 401. For local dev only, you
# can paste a per-farm community key here (Settings → Developer
# Options → API Key in the game) — mintFarmKey detects that shape and
# uses it as-is, restricted to that one farm.
SFL_COMMUNITY_API_KEY=

# Shared secret required in the `x-admin-secret` header for the
# admin-only POST /push/sweep endpoint (manual Coordinator sweep
# trigger). Generate with `openssl rand -hex 32`. Production uses
# a Cloudflare dashboard secret. Leave blank locally if you don't
# need to test manual sweeps — the route fails closed.
ADMIN_SECRET=
