{
  "name": "sunflower-land-overview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "git submodule update --init --recursive --depth 1",
    "dev": "vite --host",
    "worker": "vite build --config vite.worker.config.ts --watch",
    "wrangler": "wrangler dev",
    "build": "yarn build:client && yarn build:worker",
    "build:client": "tsc -b && vite build",
    "build:worker": "vite build --config vite.worker.config.ts",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "agents": "^0.12.4",
    "classnames": "^2.5.1",
    "decimal.js-light": "^2.5.1",
    "immer": "^11.1.8",
    "lodash.clonedeep": "^4.5.0",
    "lodash.isequal": "^4.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.90.0"
  }
}
