{
  "name": "sunflower-land-overview",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "git submodule update --init --recursive --depth 1",
    "dev": "vite --host",
    "worker": "vite build --config vite.worker.config.ts --watch",
    "wrangler": "wrangler dev",
    "build": "npm run build:client && npm run build:worker",
    "build:client": "tsc -b && vite build",
    "build:worker": "vite build --config vite.worker.config.ts",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc -b",
    "release": "git fetch origin && git checkout master && git pull origin master && git merge origin/development"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "agents": "^0.12.4",
    "classnames": "^2.5.1",
    "decimal.js-light": "^2.5.1",
    "immer": "^11.1.8",
    "lodash.clonedeep": "^4.5.0",
    "lodash.isequal": "^4.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260509.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.103.0"
  },
  "allowScripts": {
    "core-js-pure@3.49.0": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260617.1": true
  }
}
